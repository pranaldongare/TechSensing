# ─────────────────────────────────────────────────────────────────────
#  TechSensing — example .env
#
#  Copy this file to `.env` and fill in the values for your environment.
#  Every variable is OPTIONAL except SECRET_KEY and at least one of
#  (USE_INTERNAL credentials) or (API_KEY_* for the Gemini fallback) or
#  (a working local Ollama at QUERY_URL).
#
#  Booleans accept: 1 / true / yes / on  (anything else is false).
# ─────────────────────────────────────────────────────────────────────


# ── Required ────────────────────────────────────────────────────────
SECRET_KEY=your-jwt-secret-key

# ── App mode ────────────────────────────────────────────────────────
# Controls dev-only behavior (verbose logs, hot reload helpers, ...).
MODE=development


# ── LLM — Gemini (round-robin, at least 1 required for fallback) ────
API_KEY_1=
API_KEY_2=
API_KEY_3=
API_KEY_4=
API_KEY_5=
API_KEY_6=

# ── LLM — OpenAI (last-resort fallback) ─────────────────────────────
OPENAI_API=

# ── LLM — Local Ollama (primary inference) ──────────────────────────
MAIN_MODEL=qwen3:14b
QUERY_URL=http://localhost:11434
VISION_URL=http://localhost:11435
LOCAL_BASE_URL=http://localhost
# Ollama parallelism — match `OLLAMA_NUM_PARALLEL` on the Ollama server.
OLLAMA_NUM_PARALLEL=2

# ── LLM — Model token limits ────────────────────────────────────────
MODEL_CONTEXT_TOKENS=32000
MODEL_OUTPUT_TOKENS=16000
MODEL_OUTPUT_RESERVE=4000

# ── LLM — Client tuning (timeouts, concurrency, cache) ──────────────
# Append every HTTP exchange to DEBUG/llm_calls/*.jsonl. Set to "false"
# if disk usage becomes a concern; everything still works without it.
LLM_CALL_LOG=true
# Global concurrency cap across the whole process (semaphore).
LLM_MAX_CONCURRENCY=2
# Per-provider timeouts, in seconds.
LLM_GPU_TIMEOUT=1200
LLM_GEMINI_TIMEOUT=180
LLM_OPENAI_TIMEOUT=180
# Gemini output cap.
LLM_GEMINI_MAX_TOKENS=16384
# Max LangChain LLM objects to keep cached in memory.
LLM_CACHE_MAX=8


# ── Optional — INTERNAL LLM API (default disabled) ──────────────────
# Set USE_INTERNAL=true and fill the five credentials to route LLM
# calls through the corporate INTERNAL API before falling back to the
# local Ollama / Gemini / OpenAI chain.
USE_INTERNAL=false
INTERNAL_BASE_URL=
INTERNAL_CLIENT_KEY=
INTERNAL_API_TOKEN=
INTERNAL_USER_EMAIL=
INTERNAL_MODEL_ID=
# Max output tokens per INTERNAL call. Default 8000 (8K) matches PRISM.
INTERNAL_MAX_NEW_TOKENS=8000
# Debug aid: when true, INTERNAL failures raise immediately instead of
# falling through to GPU/Gemini/OpenAI. Temporarily set this true to
# surface the actual INTERNAL error reason. Leave false in production.
INTERNAL_NO_FALLBACK=false
# Hybrid mode: when true (alongside USE_INTERNAL=true) the article
# classifier alone routes to the local GPU LLM while every OTHER LLM
# call still goes through INTERNAL. Use this when the INTERNAL content
# filter blocks the classifier prompt (FR-201) but works fine for the
# rest of the pipeline. INTERNAL_NO_FALLBACK is ignored for the
# bypassed classifier call.
INTERNAL_BYPASS_CLASSIFIER=false


# ── Optional — Tech Sensing tuning knobs ────────────────────────────
# DuckDuckGo concurrency cap during article ingest.
DDG_MAX_CONCURRENCY=1
# Key Companies stage timeouts (seconds).
KC_GATHER_TIMEOUT_S=180
KC_LLM_TIMEOUT_S=240
KC_BRIEFING_TIMEOUT_S=480


# ── Optional — Data Source API keys ─────────────────────────────────
ARTIFICIAL_ANALYSIS_API_KEY=
YOUTUBE_API_KEY=
PATENTSVIEW_API_KEY=
EPO_CONSUMER_KEY=
EPO_CONSUMER_SECRET=
TAVILY_API_KEY=
LENS_API_KEY=
# GitHub Personal Access Token — used by GitHub trending + provider for
# higher rate limits. Public scope is enough.
GITHUB_TOKEN=
# SEC EDGAR requires a descriptive User-Agent with contact info on
# every request. Replace with your own org + contact email.
SEC_EDGAR_USER_AGENT=TechSensing research-agent contact@example.com


# ── Optional — Email Digest (SMTP) ──────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# From-address override; defaults to SMTP_USER if blank.
SMTP_FROM=
SMTP_USE_TLS=true


# ─────────────────────────────────────────────────────────────────────
#  Sensing feature flags (all have sane defaults — only override the
#  ones you actively want to flip). Each variable accepts true / false.
#  Defaults are shown in the comment beside each line.
# ─────────────────────────────────────────────────────────────────────

# ── Technology Radar master switch ─────────────────────────────────
# When false (default), the Phase 2 radar generation step AND all 8
# signal/scoring enrichment stages (movement, signal_strength,
# source_count, lifecycle, momentum, funding, relationships,
# weak_signals, trending_videos) are skipped. Set true to bring back
# the radar section, relationships graph, weak signals, video badges,
# and signal/momentum indicators.
SENSING_FEATURE_TECH_RADAR=false

# ── Evidence-breadth providers (Phase 2) — default OFF ─────────────
# SENSING_FEATURE_RSS=false
# SENSING_FEATURE_GITHUB=false
# SENSING_FEATURE_ARXIV=false
# SENSING_FEATURE_PRESS_WIRE=false
# SENSING_FEATURE_YOUTUBE=false
# SENSING_FEATURE_EDGAR=false
# SENSING_FEATURE_PATENTS=false

# ── Trust / UX (Phase 1) — default ON ──────────────────────────────
# SENSING_FEATURE_SOURCE_EVIDENCE=true
# SENSING_FEATURE_SS_DOWNGRADE=true
# SENSING_FEATURE_SENTIMENT=true
# SENSING_FEATURE_TELEMETRY=true
# SENSING_FEATURE_BYO_URLS=true
# SENSING_FEATURE_ALIASES=true
# SENSING_FEATURE_EXCLUSIONS=true

# ── Output richness (Phase 3) — mostly ON ──────────────────────────
# SENSING_FEATURE_MOMENTUM=true
# SENSING_FEATURE_OVERLAP=true
# SENSING_FEATURE_THEMES=false
# SENSING_FEATURE_TIMELINE=true
# SENSING_FEATURE_CROSS_DOMAIN=true
# SENSING_FEATURE_INVESTMENT=true

# ── Persistence (Phase 4) — mostly ON ──────────────────────────────
# SENSING_FEATURE_WATCHLISTS=true
# SENSING_FEATURE_SCHEDULED_DIGEST=false
# SENSING_FEATURE_DIFF=true
# SENSING_FEATURE_SIMILAR=true

# ── Exports (Phase 5) — mostly ON ──────────────────────────────────
# SENSING_FEATURE_KC_PDF_PPTX=true
# SENSING_FEATURE_CSV_XLSX=true
# SENSING_FEATURE_MD_NOTION=true
# SENSING_FEATURE_JIRA=false

# ── Heavy compute (Phase 6) — mixed defaults ───────────────────────
# SENSING_FEATURE_FOLLOW_UP=true
# SENSING_FEATURE_CONTRADICTIONS=false
# SENSING_FEATURE_HALLUCINATION=false
# SENSING_FEATURE_HIRING=false
# SENSING_FEATURE_OPP_THREAT=true

# ── Leading Indicator Radar (LIR) ──────────────────────────────────
# SENSING_FEATURE_LIR=true
# SENSING_FEATURE_LIR_ARXIV=true
# SENSING_FEATURE_LIR_GITHUB=true
# SENSING_FEATURE_LIR_HN=true
# SENSING_FEATURE_LIR_REDDIT=true
# SENSING_FEATURE_LIR_SEMSCHOLAR=true
# SENSING_FEATURE_LIR_HF=true
# SENSING_FEATURE_LIR_PYPI=true
# SENSING_FEATURE_LIR_VENDOR=true
# SENSING_FEATURE_LIR_STANDARDS=true
# SENSING_FEATURE_LIR_PATENTS=false
# SENSING_FEATURE_LIR_OPENALEX=true
# SENSING_FEATURE_LIR_GTRENDS=false
# SENSING_FEATURE_LIR_STACKEX=true
# SENSING_FEATURE_LIR_JOBS=true
